.env.local
.env.*.local
.env.development
.env.production
.env.test
*.env

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build outputs
dist/
build/
out/
.next/
*.tsbuildinfo

# IDE and editors
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Testing and coverage
coverage/
.nyc_output/
*.lcov

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pids/
*.pid
*.seed
*.pid.lock

# Temporary files
tmp/
temp/
*.tmp
*.temp

# Database files (if using local SQLite)
*.db
*.sqlite
*.sqlite3

# Secrets and credentials - SENSITIVE
secrets/
credentials/
*.key
*.pem
*.cert
*.crt
*.p12
*.pfx

# Cloud provider configs - SENSITIVE
.aws/
.gcloud/
.azure/

# Docker
.dockerignore
docker-compose.override.yml

# Backup files
*.bak
*.backup
*.old

# Cache
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

